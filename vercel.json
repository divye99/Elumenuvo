{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/reap-sandboxes",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expire-pending-orders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/log-daily-prices",
      "schedule": "45 2 * * *"
    }
  ]
}
