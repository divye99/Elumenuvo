# ── Supabase ───────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Drizzle migrations + server queries) ─────────
# Project Settings → Database → Connection string → URI (Transaction pooler).
# Make sure to URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── Sandbox / trial ────────────────────────────────────────
# Secret used to HMAC-sign the per-visitor sandbox cookie. Generate a random
# string (e.g. `openssl rand -base64 32`).
SANDBOX_COOKIE_SECRET=change-me-to-a-long-random-string
# Bearer token Vercel Cron uses to call /api/cron/reap-sandboxes.
CRON_SECRET=change-me-to-a-random-string

# ── Admin (/admin) ─────────────────────────────────────────
# Password for the /admin screen. Writes also require SUPABASE_SERVICE_ROLE_KEY.
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Order emails (Resend) ──────────────────────────────────
# resend.com → API Keys. Without RESEND_API_KEY, order/confirmation/status
# emails are skipped (logged only) — orders still work.
RESEND_API_KEY=
# Verified sender (must be a domain you've verified in Resend).
ORDER_FROM_EMAIL=Elume <orders@elumenuvo.com>
# Where new-order alerts are sent (defaults to divye2014@gmail.com).
ADMIN_EMAIL=divye2014@gmail.com
# Base URL for tracking links in emails.
NEXT_PUBLIC_SITE_URL=https://elumenuvo.com

# ── Competitor price radar (optional) ──────────────────────
# Pincode Vashi net prices are quoted for (default 400001).
VASHI_PINCODE=400001
